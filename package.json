{
  "name": "vigen-aio",
  "version": "1.0.0",
  "description": "All-in-One AI Video Generator Desktop App",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"electron .\"",
    "start": "electron .",
    "build": "node build.js",
    "vite-build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@remotion/bundler": "^4.0.190",
    "@remotion/player": "^4.0.190",
    "@remotion/renderer": "^4.0.190",
    "axios": "^1.7.9",
    "bytenode": "^1.6.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.475.0",
    "msedge-tts": "^2.0.7",
    "pdfkit": "^0.19.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.190",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3",
    "javascript-obfuscator": "^5.4.3",
    "jimp": "^1.6.1",
    "png-to-ico": "^3.0.1",
    "vite": "^6.0.7"
  },

  "build": {
    "appId": "com.vigen.aio.studio",
    "productName": "ViGen AIO Studio",
    "directories": {
      "app": "dist-build",
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "asar": true,
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ],
      "publish": [
        {
          "provider": "github",
          "owner": "linhlinh897986",
          "repo": "AI_Studio-Releases",
          "releaseType": "draft"
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ViGen AIO Studio",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  }
}

