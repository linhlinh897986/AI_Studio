<script type="text/javascript" language="javascript">
	window.onload = function() {
		if (document.getElementById("album").checked) {
			var lookup_url = album_url;
		}
		else if (document.getElementById("song").checked) {
			var lookup_url = song_url;
		}
		else if (document.getElementById("singer").checked) {
			var lookup_url = singer_url;
		}
		else if (document.getElementById("ebook").checked) {
			var lookup_url = ebook_url;
		}
		else if (document.getElementById("thuoc").checked) {
			var lookup_url = thuoc_url;
		}
		else if (document.getElementById("truyentranh").checked) {
			var lookup_url = comic_url;
		}
		else if (document.getElementById("tudien").checked) {
			var lookup_url = dict_url;
		}
		
		autocomplt = $('#keyword').autocomplete({
			maxHeight: 400,
			width:450,
			zIndex: 9999,
			delimiter: /(,|;)\s*/, // regex or character
			noCache: true, //default is false, set to true to disable caching
			onSelect: function(value, data){
				//alert('You selected: ' + value + ', ' + data);
				search_form.item_view_id.value = data;
			}, // callback function
			serviceUrl: lookup_url //url to lookup values 
		});
	}
	
	function doSearchKeyword(theform) {
		var view_id = theform.item_view_id.value;
		var thekeyword = theform.keyword.value;
		
		if (theform.truyentranh.checked) {
			location.href = "https://phapthihoi.org/truyen-tranh-phat-giao/"+view_id+"/"+thekeyword.replace(/ /g,"-")+".html";
		}
		
		if (theform.ebook.checked) {
			location.href = "https://phapthihoi.org/Doc-Ebook-Phat-Giao/"+view_id+"/"+thekeyword.replace(/ /g,"-")+".html";
		}
		
		if (theform.tudien.checked) {
			location.href = "https://phapthihoi.org/Tu-Dien-Phat-Hoc/"+view_id+"/"+thekeyword.replace(/ /g,"-")+".html";
		}
	}
</script>
