		<form method="post" onSubmit="return false;" name="quick_login">
<div id='login_loading' style='display:none;margin-bottom:5'></div>
<div class="title_right">Đăng nhập</div><br clear="all">
<div class="right_content">
	<input size="20" type="text" name="name" maxlength="50" value="Tên đăng nhập" onfocus="checkUsername(this);" onblur="checkUsername(this);"><br>	
	<input size="20" type="password" name="pwd" maxlength="50" value="Mật khẩu" onfocus="this.value='';"><br>	
	<input type="submit" value="&nbsp;&nbsp;Đăng Nhập&nbsp;&nbsp;" class="button" onClick="return login('quick_login');"><br />
	<a href="https://phapthihoi.org/index.php?go=register">» Đăng ký mới «</a><br />
	<a href="https://phapthihoi.org/index.php?go=user&act=forgotpassword">» Quên mật khẩu «</a><br />
</div>
</form>
<script type="text/javascript" language="javascript">
	function checkUsername(obj) {
		if (obj.value=="Tên đăng nhập") {
			obj.value = "";
			return;
		}
		
		if (obj.value=="") {
			obj.value = "Tên đăng nhập";
			return;
		}
	}
</script>
		
