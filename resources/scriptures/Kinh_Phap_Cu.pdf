	<input size="20" type="text" name="name" maxlength="50" value="Tên đăng nhập" onfocus="checkUsername(this);" onblur="checkUsername(this);"><br>	
	<input size="20" type="password" name="pwd" maxlength="50" value="Mật khẩu" onfocus="this.value='';"><br>	
	<input type="submit" value="&nbsp;&nbsp;Đăng Nhập&nbsp;&nbsp;" class="button" onClick="return login('quick_login');"><br />
