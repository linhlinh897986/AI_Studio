</form>
<script type="text/javascript" language="javascript">
	function checkUsername(obj) {
		if (obj.value=="Tên đăng nhập") {
			obj.value = "";
			return;
		}
		
		if (obj.value=="") {
			obj.value = "Tên đăng nhập";
			return;
		}
	}
</script>
		
